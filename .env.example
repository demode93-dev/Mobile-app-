# Copy this file to .env (or .env.local) and fill in real values as needed.
# Everything here is optional - the game runs fully offline/mocked with none
# of these set.

# Netlify Functions (server-side) --------------------------------------

# FaunaDB secret for persisting leaderboard scores. Unset -> submit-run-score
# and get-leaderboard fall back to "accepted but not persisted" / empty
# leaderboard responses, and the client's local-storage fallback takes over.
FAUNA_SECRET=

# HMAC secret for verifying rewarded-ad completion tokens server-side.
# Unset -> verify-ad-reward trusts the client (dev/offline mode).
AD_REWARD_SECRET=

# Client (Vite, must be prefixed VITE_ to reach the browser bundle) -----

# Google AdSense for Games (Ad Placement API) publisher client ID, e.g.
# "ca-pub-1234567890123456". Unset -> AdSenseProvider never loads Google's
# script and the game uses AdManager's MockAdProvider instead, so rewarded
# ads keep working end-to-end without any real credentials.
VITE_ADSENSE_CLIENT_ID=
